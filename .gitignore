# ─────────────────────────────
# 🔧 .NET Build Outputs
# ─────────────────────────────
**/bin/
**/obj/
out/
publish/

# ─────────────────────────────
# 🔐 Environment / Secrets (CRITICAL)
# ─────────────────────────────
.env
*.env
.env.*
compose.env
docker.env

# keep local-only overrides out of git
docker-compose.override.yml
compose.override.yml

# ─────────────────────────────
# 🐳 Docker runtime artifacts
# ─────────────────────────────
*.pid
*.log

# ─────────────────────────────
# 🧪 EF Core (keep real migrations, ignore noise)
# ─────────────────────────────
**/Migrations/*Designer.cs
**/Migrations/*.Designer.cs
**/Migrations/*.Snapshot.cs

# (DO NOT ignore real migration files)

# ─────────────────────────────
# 🖥️ Visual Studio / Rider / IDE
# ─────────────────────────────
.vs/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates

# ─────────────────────────────
# 🪟 Windows / macOS system files
# ─────────────────────────────
.DS_Store
Thumbs.db

# ─────────────────────────────
# ⚙️ Local scripts (IMPORTANT for your setup)
# ─────────────────────────────
*.bat
*.cmd
*.sh

# ─────────────────────────────
# 📦 Node / optional future frontend safety
# ─────────────────────────────
node_modules/

# ─────────────────────────────
# 🚀 GitHub Actions / CI local caches
# ─────────────────────────────
.github/.cache/